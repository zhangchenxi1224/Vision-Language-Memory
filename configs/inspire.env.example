# Non-secret runtime contract for the existing Inspire H200 notebook.
# Do not put account passwords, proxy tokens, or Hugging Face tokens here.
export VLM_INSPIRE_INSTANCE=vlm-r3-h200x2-live-20260717
export VLM_INSPIRE_WORKSPACE='分布式训练空间'
export VLM_INSPIRE_PROJECT='前沿课题探索'
export VLM_INSPIRE_IMAGE='ngc-pytorch:25.02-cuda12.8.0-py3'
export VLM_INSPIRE_NODE=qb-prod-gpu2007

export VLM_EXPECTED_PYTHON=3.12
export VLM_EXPECTED_TORCH='2.7.0a0+ecf3bae40a.nv25.02'
export VLM_EXPECTED_CUDA=12.8
export VLM_EXPECTED_DRIVER=570.124.06
export VLM_EXPECTED_GPU_COUNT=2
export VLM_EXPECTED_GPU_NAME=H200
export VLM_MIN_GPU_MEMORY_MIB=140000
export VLM_MIN_CPUS=40
export VLM_MIN_MEMORY_GIB=390
export VLM_MIN_SHM_GIB=120

# Replace PROJECT_USER with the project-personal directory reported by
# `inspire notebook path list`; the container user is root and is not the
# project account name.
export VLM_VENV_ROOT=/inspire/ssd/project/exploration-topic/PROJECT_USER/envs/vlm-r3-ngc2502
export VLM_MODEL_ROOT=/inspire/qb-ilm/project/exploration-topic/PROJECT_USER/models/vision-language-memory
export VLM_RUN_ROOT=/inspire/ssd/project/exploration-topic/PROJECT_USER/runs/vision-language-memory-r3
export HF_HOME=/inspire/qb-ilm/project/exploration-topic/PROJECT_USER/cache/huggingface
export TORCH_HOME=/inspire/qb-ilm/project/exploration-topic/PROJECT_USER/cache/torch

# Internal package source. Public model/source downloads are prepared through
# a reachable notebook or Inspire's egress bridge; credentials never belong in
# this file.
export VLM_PIP_INDEX_URL=http://nexus.sii.shaipower.online/repository/pypi/simple/
export VLM_PIP_TRUSTED_HOST=nexus.sii.shaipower.online

# Formal R3 determinism contract.
export PYTHONHASHSEED=0
export CUBLAS_WORKSPACE_CONFIG=:4096:8
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export TOKENIZERS_PARALLELISM=false
